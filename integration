    "failure_type": "TIMEOUT",
    "retryable": true,
    "attempts_used": 2,
    "max_retries": 3
  },
  "policy_decision_ref": "pol-sup-001",
  "next_action": {
    "target_component": "orchestrator",
    "action": "retry_task",
    "task_id": "task-02"
  },
  "replan_required": false,
  "escalation_required": false,
  "human_approval_required": false,
  "safe_summary": "Supervisor approved one more retry for task-02."
}
```

